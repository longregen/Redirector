{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2020", "DOM"],
    "types": ["node"]
  },
  "include": [
    "e2e/**/*.js",
    "scripts/**/*.js",
    "playwright.config.js"
  ],
  "exclude": [
    "node_modules",
    "build",
    "screenshots",
    "test-results",
    "playwright-report"
  ]
}
