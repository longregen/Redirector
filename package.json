{
  "name": "redirector",
  "version": "1.0.0",
  "description": "Web browser extension (Firefox, Vivaldi, Chrome, Opera, Edge) to redirect URLs based on regex or wildcard patterns.",
  "main": "index.js",
  "scripts": {
    "lint": "node scripts/lint.js",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --audit-level=high --omit=dev",
    "test": "npx playwright test",
    "test:mobile": "npx playwright test --project mobile-firefox",
    "test:desktop": "npx playwright test --project desktop-chrome",
    "build": "python3 build.py",
    "screenshots": "SCREENSHOT_MODE=1 npx playwright test && node scripts/build-gallery.js",
    "screenshots:build": "node scripts/build-gallery.js"
  },
  "repository": {
    "type": "git",
    "url": "http://local_proxy@127.0.0.1:46641/git/longregen/Redirector"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
